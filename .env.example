# Alpaca paper API keys (paper dashboard)
APCA_API_KEY_ID="YOUR_KEY"
APCA_API_SECRET_KEY="YOUR_SECRET"

# Optional: override defaults
# SYMBOLS="SPY,QQQ,AAPL,MSFT,AMZN,NVDA,TSLA,META,GOOGL,AMD"
# BAR_TIMEFRAME="1Min"
# MARKET_DATA_MODE="rest"
# REST_BAR_POLL_INTERVAL_S="15"
# Free IEX bars are delayed; set end a few minutes behind "now" (default 18).
# REST_BAR_END_LAG_MINUTES="18"
# BAR_BUFFER_MAXLEN="3000"
# Market-wide scanner (daily liquid universe)
# UNIVERSE_ENABLED="false"
# UNIVERSE_MAX_SYMBOLS="750"
# UNIVERSE_LOOKBACK_DAYS="20"
# UNIVERSE_MIN_PRICE="2"
# UNIVERSE_MIN_AVG_DOLLAR_VOL="20000000"
# MAX_GROSS_EXPOSURE_PCT="0.5"
# MAX_POSITIONS="5"
# MAX_TRADES_PER_DAY="20"
# MAX_NOTIONAL_PER_TRADE_USD="0"  # set to 20 for "$20 max per trade" sizing
# PER_SYMBOL_COOLDOWN_S="600"
# MAX_DAILY_LOSS_PCT="0.03"
# DAILY_PROFIT_TARGET_USD="100"
# RISK_PER_TRADE_PCT="0.005"
# OPEN_DELAY_MINUTES="5"
# MARKET_CONTEXT_FILTER="false"
# SPY_5M_RSI_MIN="35"
# RSI_PULLBACK_MAX="42"
# VOLUME_CONFIRM_MULT="1.0"
# HTF_RSI_MIN="45"
# ATR_REGIME_MAX_MULT="2.5"
# TAKE_PROFIT_R_MULT="1.5"
# STOP_LOSS_ATR_MULT="1.5"
# Smarter exits (optional)
# MAX_HOLD_MINUTES="0"          # e.g. 45 to force-close after 45 minutes
# MODEL_EXIT_ENABLED="false"    # close positions if model confidence degrades
# MODEL_EXIT_MIN_PROBA="0.45"
# Dynamic hold-time (optional; uses TA/ML context to choose a target)
# DYNAMIC_HOLD_ENABLED="true"
# BASE_HOLD_MINUTES="45"
# MIN_HOLD_MINUTES="10"
# MAX_HOLD_MINUTES_DYNAMIC="90"
# HOLD_ATR_RATIO_WEIGHT="-15"   # higher vol (ATR/ATR_AVG) -> shorter hold
# HOLD_MODEL_PROBA_WEIGHT="20"  # higher model_p -> longer hold
# OBSERVE_ONLY="false"
# SIGNAL_SCAN_INTERVAL_S="60"
# Optional: path to JSON from --robustness (defaults to reports/day_trade_recommendations_latest.json)
# RECOMMENDATIONS_JSON="./reports/day_trade_recommendations_latest.json"

# News provider: alpaca | alphavantage | google_rss | tickertick | both | combo
# - tickertick is no-key: https://api.tickertick.com/feed (rate-limited)
# - combo merges: alpaca + alphavantage + google_rss + tickertick (whatever is reachable)
# NEWS_PROVIDER="alpaca"
# ALPHAVANTAGE_API_KEY="your_key_here"
# No-key option:
# NEWS_PROVIDER="google_rss"
# Another no-key option:
# NEWS_PROVIDER="tickertick"

# Optional: TAAPI indicators confirmation (https://taapi.io/documentation/stocks/)
# INDICATOR_PROVIDER="local"   # local | taapi
# TAAPI_SECRET="your_taapi_secret"
# TAAPI_CONFIRM_ON_TRADE="true"
# TAAPI_FAIL_OPEN="true"       # if TAAPI rate-limits, don't block trades

# Alpaca Market Data news (plan-dependent). Modes: off | log_only | skip_if_any | skip_if_busy
# NEWS_FETCH_ENABLED="true"
# NEWS_LOOKBACK_HOURS="6"
# NEWS_LIMIT="8"
# NEWS_GATE_MODE="log_only"
# NEWS_BUSY_MIN_ARTICLES="5"

# Label BUY signals with forward return vs signal-time close (min wall-clock age before label).
# SIGNAL_ACCURACY_ENABLED="true"
# SIGNAL_ACCURACY_MIN_AGE_MINUTES="15"

# Smaller robustness grids (faster; GitHub workflow sets this true)
# ROBUSTNESS_LIGHT="false"

