# Alpaca paper API keys (paper dashboard)
APCA_API_KEY_ID="YOUR_KEY"
APCA_API_SECRET_KEY="YOUR_SECRET"

# Optional: override defaults
# SYMBOLS="SPY,QQQ,AAPL,MSFT,AMZN,NVDA,TSLA,META,GOOGL,AMD"
# BAR_TIMEFRAME="1Min"
# MARKET_DATA_MODE="rest"
# REST_BAR_POLL_INTERVAL_S="15"
# Free IEX bars are delayed; set end a few minutes behind "now" (default 18).
# REST_BAR_END_LAG_MINUTES="18"
# MAX_GROSS_EXPOSURE_PCT="0.5"
# MAX_POSITIONS="5"
# MAX_TRADES_PER_DAY="20"
# PER_SYMBOL_COOLDOWN_S="600"
# MAX_DAILY_LOSS_PCT="0.03"
# DAILY_PROFIT_TARGET_USD="100"
# RISK_PER_TRADE_PCT="0.005"
# OPEN_DELAY_MINUTES="5"
# MARKET_CONTEXT_FILTER="false"
# SPY_5M_RSI_MIN="35"
# RSI_PULLBACK_MAX="42"
# VOLUME_CONFIRM_MULT="1.0"
# HTF_RSI_MIN="45"
# ATR_REGIME_MAX_MULT="2.5"
# TAKE_PROFIT_R_MULT="1.5"
# STOP_LOSS_ATR_MULT="1.5"
# OBSERVE_ONLY="false"
# SIGNAL_SCAN_INTERVAL_S="60"

